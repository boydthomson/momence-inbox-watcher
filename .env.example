# ============================================================
# Momence Inbox Watcher — configuration
# Copy to .env and fill in. Keep .env private (it holds secrets).
# ============================================================

# --- Momence (required) -------------------------------------
# Your host id: log into the dashboard and look at the URL:
#   https://momence.com/dashboard/<HOST_ID>/dashboard
MOMENCE_HOST_ID=

# The value of the `ribbon.connect.sid` cookie from a logged-in dashboard
# session. In your browser: DevTools (F12) -> Storage/Application -> Cookies
# -> momence.com -> copy the VALUE of ribbon.connect.sid (it is URL-encoded,
# starts with "s%3A" — paste it exactly as shown).
# NOTE: this is a session cookie and will eventually expire. The watcher
# notifies you when it does; paste a fresh value and restart.
MOMENCE_SESSION_COOKIE=

# --- Notifications (Apprise URLs, comma-separated) ----------
# Any combination of ~80 services. Full list + URL formats:
#   https://github.com/caronc/apprise/wiki
#
# Matrix:
#   matrixs://<user_token>@matrix.example.org/#room-alias  (https)
#   matrix://...                                            (http)
#   e.g. matrixs://syt_xxx@matrix.dyob.ca/!roomid:matrix.dyob.ca
# Telegram:
#   tgram://<bot_token>/<chat_id>
# Discord webhook:
#   discord://<webhook_id>/<webhook_token>
# Slack webhook:
#   slack://<tokenA>/<tokenB>/<tokenC>
# ntfy:
#   ntfy://ntfy.sh/<your-topic>
# Email (SMTP):
#   mailto://user:pass@smtp.example.com?to=you@example.com
# Pushover:
#   pover://<user_key>@<app_token>
#
# Leave empty to print alerts to the container log only.
APPRISE_URLS=

# --- Tuning (optional) ---------------------------------------
# How often to poll, in seconds (default 60)
POLL_INTERVAL_SECONDS=60
